# Copy to stockrag/.env and fill in your keys.
# `npm run cold-start` will create this for you interactively if missing.

# Required — https://aistudio.google.com/apikey
# (GOOGLE_API_KEY is also accepted as a fallback)
GEMINI_API_KEY=

# Optional — https://finnhub.io/register (live stock prices)
FINNHUB_API_KEY=

# Optional overrides (defaults shown)
API_PORT=8000
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=1200
DEFAULT_TOP_K=5
RETRIEVAL_TOP_K=20
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=../chroma_db
FISCAL_YEAR_LOOKBACK=5

# Cold-start only — where the prebuilt Chroma snapshot is fetched from on first
# run. Defaults to the public HF dataset baked into scripts/cold-start.mjs.
# Set CHROMA_DB_URL= (empty) to skip the download and start with an empty store.
CHROMA_DB_URL=
CHROMA_DB_SHA256_URL=
